# RescueBite — API (NestJS + Prisma + PostgreSQL)
# Copy to .env and fill in.

# Postgres connection string used by Prisma
DATABASE_URL=postgresql://rescuebite:rescuebite@localhost:5432/rescuebite?schema=public

# HTTP server
PORT=4000
NODE_ENV=development

# Comma-separated list of allowed CORS origins (the three frontends)
CORS_ORIGINS=http://localhost:3001,http://localhost:3002,http://localhost:8081

# Auth (JWT signing secret — generate a strong random value per environment)
JWT_SECRET=change-me-in-every-environment
JWT_EXPIRES_IN=7d
