# RescueBite — API (NestJS + Prisma + PostgreSQL)
# Copy to .env and fill in.

# Postgres connection string used by Prisma
DATABASE_URL=postgresql://rescuebite:rescuebite@localhost:5432/rescuebite?schema=public

# HTTP server
PORT=4000
NODE_ENV=development

# Comma-separated list of allowed CORS origins (the three frontends)
CORS_ORIGINS=http://localhost:3001,http://localhost:3002,http://localhost:8081

# Auth (JWT signing secret — generate a strong random value per environment)
JWT_SECRET=change-me-in-every-environment
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DAYS=30
APP_WEB_URL=http://localhost:3001

# Reservations hold stock this many minutes before auto-release
RESERVATION_HOLD_MINUTES=15

# S3-compatible storage for listing images (optional in dev → falls back to a stub)
# S3_BUCKET=
# S3_REGION=us-east-1
# S3_ENDPOINT=
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_PUBLIC_URL=

# Stripe (test mode). Get keys at https://dashboard.stripe.com/test/apikeys
# When unset, payment endpoints return 503 and the rest of the API still works.
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxx
# From `stripe listen` (see README) or the Dashboard webhook endpoint signing secret
STRIPE_WEBHOOK_SECRET=whsec_xxx
# Platform commission in basis points (1000 = 10%)
PLATFORM_FEE_BPS=1000
