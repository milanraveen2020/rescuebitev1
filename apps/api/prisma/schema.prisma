// RescueBite database schema.
// Mirrors the Zod domain models in @rescuebite/types — the Zod schemas remain the
// single source of truth for API request/response validation; Prisma owns persistence.
// Money is stored as integer minor units (e.g. cents); never floats.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum UserRole {
  CUSTOMER
  MERCHANT_OWNER
  MERCHANT_STAFF
  ADMIN
}

enum UserStatus {
  ACTIVE
  SUSPENDED
}

enum StoreStatus {
  PENDING
  APPROVED
  REJECTED
}

enum FoodCategory {
  BAKERY
  GROCERY
  RESTAURANT
  CAFE
  PRODUCE
  OTHER
}

enum ListingStatus {
  DRAFT
  ACTIVE
  SOLD_OUT
  EXPIRED
}

enum OrderStatus {
  RESERVED
  PAID
  COLLECTED
  CANCELLED
  REFUNDED
  NO_SHOW
}

enum NotificationType {
  ORDER_RESERVED
  ORDER_PAID
  ORDER_REFUNDED
  PICKUP_REMINDER
  ORDER_COLLECTED
  ORDER_CANCELLED
  NEW_ORDER
  STORE_APPROVED
  STORE_REJECTED
  NEW_LISTING
  REVIEW_REQUEST
  SYSTEM
}

enum DevicePlatform {
  IOS
  ANDROID
  WEB
}

// ---------------------------------------------------------------------------
// Models
// ---------------------------------------------------------------------------

model User {
  id              String     @id @default(uuid())
  email           String     @unique
  phone           String?    @unique
  passwordHash    String
  role            UserRole   @default(CUSTOMER)
  name            String
  avatarUrl       String?
  status          UserStatus @default(ACTIVE)
  emailVerifiedAt DateTime?
  // MERCHANT_STAFF members belong to one store (owners use ownedStores instead).
  staffStoreId    String?
  staffStore      Store?     @relation("StoreStaff", fields: [staffStoreId], references: [id], onDelete: SetNull)
  // Per-channel/category notification opt-outs; null means platform defaults.
  notificationPrefs Json?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  ownedStores        Store[]             @relation("StoreOwner")
  orders             Order[]
  reviews            Review[]
  notifications      Notification[]
  favorites          Favorite[]
  auditLogs          AuditLog[]          @relation("AuditActor")
  refreshTokens      RefreshToken[]
  verificationTokens VerificationToken[]
  deviceTokens       DeviceToken[]

  @@index([role])
  @@index([staffStoreId])
}

enum TokenType {
  EMAIL_VERIFICATION
  PASSWORD_RESET
}

/// Opaque refresh tokens, stored only as an argon2 hash. Rotated on every use.
model RefreshToken {
  id        String    @id @default(uuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String
  expiresAt DateTime
  revokedAt DateTime?
  userAgent String?
  createdAt DateTime  @default(now())

  @@index([userId])
}

/// Single-use tokens for email verification and password reset (stored hashed).
model VerificationToken {
  id        String    @id @default(uuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      TokenType
  tokenHash String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId, type])
}

model Store {
  id              String       @id @default(uuid())
  ownerId         String
  owner           User         @relation("StoreOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  name            String
  description     String?
  category        FoodCategory
  address         String
  lat             Float
  lng             Float
  logoUrl         String?
  coverUrl        String?
  openingHours    String?      // free-text opening hours, e.g. "Mon–Fri 9–18"
  currency        String       @default("LKR")
  stripeAccountId String?
  payoutsEnabled  Boolean      @default(false)
  rating          Float        @default(0) // denormalized average of approved reviews
  reviewCount     Int          @default(0) // denormalized count, kept in sync with reviews
  status          StoreStatus  @default(PENDING)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  listings  Listing[]
  orders    Order[]
  reviews   Review[]
  favorites Favorite[]
  staff     User[]       @relation("StoreStaff")

  @@index([ownerId])
  @@index([status])
  @@index([lat, lng])
}

/// A "surprise bag": a quantity of discounted surplus food for a pickup window.
model Listing {
  id                String        @id @default(uuid())
  storeId           String
  store             Store         @relation(fields: [storeId], references: [id], onDelete: Cascade)
  title             String
  description       String?
  category          FoodCategory
  originalPrice     Int // minor units (cents)
  price             Int // minor units (cents)
  quantityTotal     Int
  quantityRemaining Int
  pickupStart       DateTime
  pickupEnd         DateTime
  imageUrl          String?
  allergenInfo      String?
  status            ListingStatus @default(DRAFT)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  orders Order[]

  @@index([storeId, status])
  @@index([pickupEnd])
  @@index([status])
}

model Order {
  id                    String      @id @default(uuid())
  customerId            String
  customer              User        @relation(fields: [customerId], references: [id])
  listingId             String
  listing               Listing     @relation(fields: [listingId], references: [id])
  storeId               String
  store                 Store       @relation(fields: [storeId], references: [id])
  quantity              Int
  unitPrice             Int // minor units (cents) at time of order
  totalAmount           Int // minor units (cents)
  currency              String      @default("LKR")
  status                OrderStatus @default(RESERVED)
  pickupCode            String      @unique // short human-friendly collection code
  stripePaymentIntentId String?
  // While RESERVED, stock is held until this time, then auto-released.
  reservationExpiresAt  DateTime?
  createdAt             DateTime    @default(now())
  collectedAt           DateTime?
  updatedAt             DateTime    @updatedAt

  review Review?

  @@index([status, reservationExpiresAt])

  @@index([customerId])
  @@index([storeId, status])
  @@index([listingId])
}

model Review {
  id         String    @id @default(uuid())
  orderId    String    @unique // one review per order
  order      Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  customerId String
  customer   User      @relation(fields: [customerId], references: [id])
  storeId    String
  store      Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)
  rating     Int // 1..5
  comment    String?
  // Set by an admin when moderating abusive content; hidden reviews are excluded
  // from public listings and from the store's denormalized rating.
  hiddenAt   DateTime?
  createdAt  DateTime  @default(now())

  @@index([storeId])
  @@index([customerId])
}

/// Single-row table of operator-tunable platform settings (id is always "singleton").
model PlatformSettings {
  id                String         @id @default("singleton")
  commissionBps     Int            @default(1000) // platform fee in basis points
  enabledCategories FoodCategory[]
  featureFlags      Json           @default("{}")
  updatedAt         DateTime       @updatedAt
}

model Notification {
  id        String           @id @default(uuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  title     String
  body      String
  data      Json?
  // Deterministic per-event key so re-delivered events don't duplicate rows.
  dedupeKey String?          @unique
  readAt    DateTime?
  createdAt DateTime         @default(now())

  @@index([userId, readAt])
}

/// An Expo push token registered for a user's device. Tokens are unique; a token
/// re-registering for a new user is reassigned (one device = one user).
model DeviceToken {
  id        String         @id @default(uuid())
  userId    String
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String         @unique
  platform  DevicePlatform
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@index([userId])
}

model Favorite {
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  storeId   String
  store     Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@id([userId, storeId])
  @@index([storeId])
}

model AuditLog {
  id        String   @id @default(uuid())
  actorId   String?
  actor     User?    @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)
  action    String
  entity    String
  entityId  String
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([actorId])
  @@index([entity, entityId])
}
