{
  "expo": {
    "name": "RescueBite",
    "slug": "rescuebite-customer",
    "scheme": "rescuebite",
    "version": "0.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "backgroundColor": "#12b76a",
      "resizeMode": "contain"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.rescuebite.customer"
    },
    "android": {
      "package": "com.rescuebite.customer",
      "adaptiveIcon": {
        "backgroundColor": "#12b76a"
      }
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-location",
        { "locationWhenInUsePermission": "RescueBite uses your location to find surprise bags nearby." }
      ],
      [
        "expo-calendar",
        { "calendarPermission": "RescueBite adds your pickup window to your calendar." }
      ]
    ],
    "experiments": {
      "typedRoutes": false
    },
    "extra": {
      "apiBaseUrl": "http://localhost:4000",
      "stripePublishableKey": "pk_test_unset"
    }
  }
}
